# NVIDIA Cosmos NIM API Key (get from build.nvidia.com)
NVIDIA_COSMOS_API_KEY=nvapi-your-key-here

# Telegram Bot (optional, python-telegram-bot v20+)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALLOWED_CHAT_IDS=              # Comma-separated, auth filter

# Hardware mode (default: false = simulation)
ANYBUS_HARDWARE=false          # true → import hms.abcc40 for real fieldbus I/O

# Video source (optional)
VIDEO_SOURCE=                  # path, rtsp://, "0" for USB cam, or empty

# Server
PORT=8080
